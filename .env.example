# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_SECRET=generate_random_secret_here

# Database Configuration (Choose one)
# Option 1: Vercel KV (Redis)
KV_URL=your_kv_url
KV_REST_API_URL=your_kv_rest_api_url
KV_REST_API_TOKEN=your_kv_rest_api_token
KV_REST_API_READ_ONLY_TOKEN=your_kv_read_only_token

# Option 2: Vercel Postgres
POSTGRES_URL=your_postgres_url
POSTGRES_PRISMA_URL=your_postgres_prisma_url
POSTGRES_URL_NON_POOLING=your_postgres_url_non_pooling
POSTGRES_USER=your_postgres_user
POSTGRES_HOST=your_postgres_host
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DATABASE=your_postgres_database

# Option 3: Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Bot Configuration
BOT_USERNAME=your_bot_username
ADMIN_IDS=comma_separated_admin_telegram_ids
DEFAULT_LANGUAGE=en

# Feature Flags
ENABLE_CAPTCHA=true
ENABLE_ML_FILTERING=false
ENABLE_LINK_CHECKING=true
ENABLE_MEDIA_SCANNING=false

# Rate Limiting
MAX_MESSAGES_PER_MINUTE=10
MAX_MENTIONS_PER_MESSAGE=3
NEW_USER_RESTRICTION_HOURS=24

# Webhook Configuration (Vercel will auto-set)
VERCEL_URL=https://your-project.vercel.app